# Convex
# Get this URL from running 'npx convex dev' in packages/convex
EXPO_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud

# Sentry Error Tracking
# Get this from sentry.io -> Project Settings -> Client Keys (DSN)
EXPO_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# Clerk
# Get this from Clerk Dashboard -> API Keys -> Publishable key
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx

# RevenueCat (optional entitlement config)
# Keep using EXPO_PUBLIC_REVENUECAT_IOS_API_KEY for your API key.
# If omitted, Pro entitlement defaults to "pro".
EXPO_PUBLIC_PRO_ENTITLEMENT_IDS=pro,premium

# Copy this file to .env and fill in the actual values
